# ─────────────────────────────────────────────────────────────────────────────
# Yosuku — consumer front-door for DeepBook Predict (Sui testnet).
#
# JUDGE QUICKSTART (runs the UI with ZERO env setup):
#   1. npm install
#   2. npm run dev        → open http://localhost:3000
#   Every on-chain address below has a real hardcoded fallback baked into the code
#   (lib/sui/network.ts, parlayClient.ts, vault624Client.ts), so markets, betting,
#   leverage, parlays, copy-trading, and cash-out all work on a fresh clone with NO
#   .env file at all. Get test USDC from the faucet linked in-app (the "Faucet"
#   button / https://yosuku.xyz). Copy this file to .env.local only to OVERRIDE.
#   NOTE: Google (zkLogin) sign-in uses the Enoki + Google keys below; those origins
#   are locked to yosuku.xyz, so on localhost use a burner wallet OR register your
#   own Enoki app key + Google OAuth client for http://localhost:3000.
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# CLIENT  —  NEXT_PUBLIC_* (safe, shipped to the browser; these are the REAL public
# values baked into the live site). All are OPTIONAL: the code already falls back to
# these exact values, so you only need to set them to point at a different deployment.
# ═════════════════════════════════════════════════════════════════════════════

# Network switch — 'testnet' (default) or 'mainnet'. DeepBook Predict is testnet-only
# today, so leave this on testnet. (lib/sui/network.ts)
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── Google / zkLogin sign-in (Enoki). Public by design; origin-restricted to the
#    deployed domain. Needed only for Google sign-in (wallet connect works without it).
NEXT_PUBLIC_ENOKI_API_KEY=enoki_public_457ab46d819538e29a2ee1d9d82352bf
NEXT_PUBLIC_GOOGLE_CLIENT_ID=353765281749-qo5imksct3ss1ficjbb7jprvv3pdqe7a.apps.googleusercontent.com

# ── Onara gas station (sponsors gas so bets are gas-free). (lib/sponsor.ts)
NEXT_PUBLIC_ONARA_URL=https://yosuku-gas.yosuku.workers.dev

# ── trade-from-X "connect wallet to your @handle" worker. Code default shown.
#    (app/trade-from-x/page.tsx)
NEXT_PUBLIC_CONNECT_URL=https://yosuku-connect.yosuku.workers.dev

# ── Sui RPC / GraphQL / gRPC endpoints. Leave blank to use the built-in multi-node
#    testnet defaults (the public fullnode JSON-RPC was sunset, so the app rotates
#    across several providers automatically). Set to pin/rotate a specific node.
#    (lib/sui/jsonRpc.ts, lib/sui/modernClients.ts)
NEXT_PUBLIC_SUI_RPC_URL=
NEXT_PUBLIC_SUI_GRAPHQL_URL=
NEXT_PUBLIC_SUI_GRPC_URL=

# ── Legacy resolver backend URL (optional; unused in the default on-chain flow).
#    (lib/predictionContract.ts, lib/backendUrl.ts)
NEXT_PUBLIC_BACKEND_URL=

# ── Deployed testnet package / object IDs. Real values, all hardcoded as fallbacks
#    in the code — set here ONLY to retarget a fresh redeploy.
# Parlay reserve (yolev parlay upgrade). (lib/sui/parlayClient.ts)
NEXT_PUBLIC_PARLAY_PACKAGE=0xd950420d3b3ac026c6f3b242010bec2dd2f7cdab6a7d68fb00087516094cbc02
NEXT_PUBLIC_PARLAY_RESERVE=0x939724d6fc82af88530368b06f952af0b7277d0da51bd419659a3bb1686c0851
# Web margin desk + prefunded Trading Balance vault (powers LEVERAGE + private + cash-out).
# (lib/sui/network.ts → tradingVaultClient.ts)
NEXT_PUBLIC_TRADING_VAULT_PACKAGE=0x3b76383b2bb9bc411dc56c571a1da22f348b3c19518115ae958fe96e031cf30e
NEXT_PUBLIC_MARGIN_DESK_ID=0x5aa4be2fb3084660e584d29a7323ea73ab96a07728496c5a3832b3b9cc0f4e40
NEXT_PUBLIC_TRADING_VAULT_ID=0xc04516b582bfe73c71325408bfb9e9a5a8fdcd54952a313a288a135e272fa1e6

# DUSDC pool object surfaced on the private-bet status card (display only; optional).
# (app/api/private-bet/status/route.ts)
NEXT_PUBLIC_VORTEX_DUSDC_POOL=


# ═════════════════════════════════════════════════════════════════════════════
# SERVER-ONLY  —  secrets + off-box service URLs. NOT needed to run the UI locally.
# These are read only inside Next.js API routes (app/api/**) that proxy the faucet,
# the private-bet / claim / agent-spec executors, and SuiNS minting. Leaving them
# unset just disables those server features; the whole trading UI still works.
# Fill with your OWN values if you run those backends — never commit real secrets.
# ═════════════════════════════════════════════════════════════════════════════

# Faucet drip signer — Sui private key that funds test-USDC requests.
# (server-only; used by the faucet API route)
FAUCET_PRIVATE_KEY=

# Private-bet (incognito) executor service + auth. (app/api/private-bet/*)
PRIVATE_BET_EXECUTOR_URL=
PRIVATE_BET_SHARED_SECRET=
PRIVATE_BET_DUSDC_POOL=

# Tweet-funded account claim/recovery executor + auth. (app/api/claim/*)
CLAIM_EXECUTOR_URL=
CLAIM_SHARED_SECRET=

# Live Desk agent-spec attestation registry + auth. (app/api/agent-spec/route.ts)
AGENT_SPEC_REGISTRY_URL=
AGENT_SPEC_SHARED_SECRET=

# SuiNS subname minting for @handle claims. (app/api/suins/claim/route.ts)
SUINS_SIGNER_KEY=
SUINS_PARENT_NFT=
# Mainnet RPC used only by the SuiNS claim route (defaults to the public fullnode).
SUI_MAINNET_RPC=

# Server-side overrides mirroring the NEXT_PUBLIC_* endpoints above (optional;
# server code prefers these when set). (lib/backendUrl.ts, lib/sui server reads)
BACKEND_URL=
SUI_RPC_URL=

# NODE_ENV is set automatically by Next.js (development / production) — do not set it here.
